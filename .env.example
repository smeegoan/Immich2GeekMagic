# Immich Configuration
IMMICH_URL=http://192.168.1.18:2283
IMMICH_API_KEY=your-immich-api-key-here

HA_URL=http://192.168.1.89:8123
HA_TOKEN=<your long-lived access token>
# HA_ENTITY=sensor.pedro_cardoso  # optional, this is the default

# GeekMagic Configuration
GEEKMAGIC_URL=http://192.168.1.107/

# GeekMagic Connection Retry Settings
# Maximum number of connection attempts before giving up (default: 10)
GEEKMAGIC_MAX_RETRIES=10

# Delay between retry attempts in seconds (default: 300 = 5 minutes)
# With 10 retries and 5-minute delays, the script will try for ~50 minutes
GEEKMAGIC_RETRY_DELAY=300

# Optional: Total storage capacity of the GeekMagic device in KB (default: 600)
# GEEKMAGIC_TOTAL_SPACE_KB=600

# Optional: Override date for testing (format: MM-DD or YYYY-MM-DD)
# TEST_DATE=12-25

# Optional: Home country to omit from location overlay (case-insensitive)
# When set, photos taken in this country will only show the city name
# HOME_COUNTRY=Portugal

# Optional: Number of random photos to show when there are no memories for today (default: 5)
# RANDOM_FALLBACK_COUNT=5
